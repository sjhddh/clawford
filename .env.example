# Required for session JWT signing (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Vercel Blob storage token (auto-set by Vercel when Blob store is connected)
BLOB_READ_WRITE_TOKEN=

# Admin bypass code for testing from rate-limited environments
ADMIN_CODE=

# LLM grading API key (FLock, OpenAI, or LiteLLM — at least one required for LLM grading/sorting)
FLOCK_API_KEY=

# Preferred attestation mode: per-sandbox secret map (JSON string).
# Example: {"tee-prod-a":"secretA","tee-prod-b":"secretB"}
TEE_SANDBOX_SECRETS_JSON=

# Legacy shared-key mode (only use if per-sandbox map is unavailable).
TEE_SHARED_SECRET=
TEE_TRUSTED_SANDBOX_IDS=

# Default pass threshold for telemetry audits when no contract score is available.
TEE_DEFAULT_PASSING_SCORE=70

# When true, /api/telemetry/audit requires skillVersion and skillHash and only revokes exact matches.
TEE_TELEMETRY_REQUIRE_BINDING=false
