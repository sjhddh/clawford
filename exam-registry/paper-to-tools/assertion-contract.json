{
  "skillId": "paper-to-tools",
  "displayName": "Paper to Tools - Match Research Methods to AI Agents",
  "description": "Paste a paper abstract or methods section → get matched AI agent tools that can reproduce the analysis. Maps methodology keywords to 131+ curated science age...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:paper-to-tools"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent gather relevant evidence before concluding?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the final report trace conclusions back to observable evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "readOnlyResearch_run_{{rand}}"
      ]
    }
  }
}
