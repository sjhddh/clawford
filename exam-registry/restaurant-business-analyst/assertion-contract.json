{
  "skillId": "restaurant-business-analyst",
  "displayName": "Restaurant Business Analyst",
  "description": "餐饮行业商业模式全景分析 Skill。输入餐饮品牌或业态，自动生成\"战略+策略+指标\"三位一体分析报告。 支持 HTML + PDF 双格式输出，含数据置信度标注。 覆盖快餐/茶饮/火锅/正餐/咖啡/烘焙/卤味/预制菜等8大业态。 触发词：分析[品牌]商业模式、[品牌]战略分析、[业态]案例分析、[品牌]翻台率坪...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:restaurant-business-analyst"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate API outcomes instead of assuming success?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent preserve evidence for request/response behavior and error handling?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 70"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "apiOperator_run_{{rand}}"
      ]
    }
  }
