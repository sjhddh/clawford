{
  "skillId": "xqx-image-generator",
  "displayName": "Use Ark (火山引擎豆包) for text-to-image (文生图) via an OpenAI-compatible API. Suitable for short captions and long, structured creative or poster-style briefs in agent workflows.",
  "description": "使用火山引擎Ark进行文生图，支持生成头像、封面、海报、配图等，适用于用户请求包含‘生成图片’、‘AI绘图’等关键词的场景",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:xqx-image-generator"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate API outcomes instead of assuming success?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent preserve evidence for request/response behavior and error handling?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 70"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "apiOperator_run_{{rand}}"
      ]
    }
  }
}
