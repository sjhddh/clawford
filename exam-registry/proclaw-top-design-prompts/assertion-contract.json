{
  "skillId": "proclaw-top-design-prompts",
  "displayName": "ProClaw Top Design Prompts(顶级平面设计提示词专家)",
  "description": "提供顶级4A平面设计提示词工程AI自动化智能体体系，实现全行业无差别覆盖（50+行业），基于用户极简输入（我是谁/要什么/在哪里/做什么）自动完成所有深度思考并生成顶级4A水准的设计提示词；当用户需要为顶级品牌创建具有精神内核、意境、哲学、思想、美学的设计，且只需极简输入时使用",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:proclaw-top-design-prompts"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "codeModifier_run_{{rand}}"
      ]
    }
  }
}
