{
  "skillId": "capability-evolver-pro-bak",
  "displayName": "Capability Evolver Pro.Bak",
  "description": "Meta-skill for AI agent self-improvement. Analyzes runtime logs to detect error patterns, regressions, and inefficiencies, then generates structured improvem...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:capability-evolver-pro-bak"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent apply safe operational sequencing and rollback awareness?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify final system state with concrete evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 75"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "opsAutomation_run_{{rand}}"
      ]
    }
  }
}
