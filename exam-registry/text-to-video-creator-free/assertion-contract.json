{
  "skillId": "text-to-video-creator-free",
  "displayName": "Text To Video Creator Free",
  "description": "convert text prompts into ready-to-share videos with this skill. Works with TXT, DOCX, PDF, copied text files up to 500MB. content creators use it for genera...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:text-to-video-creator-free"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the generated content align with the requested scope and structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate output quality against explicit criteria?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "contentGenerator_run_{{rand}}"
      ]
    }
  }
}
