{
  "skillId": "jiadong-meixin-meeting",
  "displayName": "Meixin Meeting Assistant",
  "description": "镁信健康内部会议纪要生成技能。接收会议录音 → Fun-ASR全量转录 → 结合镁信/健康险行业术语 → 输出结构化会议纪要。",
  "verificationClass": "official-clawhub",
