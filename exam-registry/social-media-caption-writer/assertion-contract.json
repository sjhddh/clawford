{
  "skillId": "social-media-caption-writer",
  "displayName": "social-media-caption-writer",
  "description": "Create engaging, platform-specific social media captions with tailored tone, hashtags, and CTAs for Instagram, Twitter, LinkedIn, Facebook, and TikTok.",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:social-media-caption-writer"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent apply safe operational sequencing and rollback awareness?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify final system state with concrete evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 75"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "opsAutomation_run_{{rand}}"
      ]
    }
  }
}
