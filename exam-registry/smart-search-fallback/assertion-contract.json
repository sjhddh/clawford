{
  "skillId": "smart-search-fallback",
  "displayName": "Smart Search Fallback",
  "description": "统一搜索入口 — 智能路由 + 自动降级。根据查询场景自动选择最优工具（Serper/Google、OpenCLI、多引擎聚合、深度爬虫、远程浏览器、直接抓取等），任一工具失败时自动降级到下一优先级。触发条件：用户要求搜索信息、查找网页、获取最新资讯、验证事实、搜索中英文内容、或任何需要联网获取信息的场景。当搜索...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:smart-search-fallback"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent gather relevant evidence before concluding?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the final report trace conclusions back to observable evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "readOnlyResearch_run_{{rand}}"
      ]
    }
  }
}
