{
  "skillId": "project-context-anchor",
  "displayName": "Dynamic Project Soul Snapshot | 动态项目灵魂快照",
  "description": "Writes AI_CONTEXT.md into the project root as a \"dynamic soul snapshot\" — capturing tech stack, recent git diffs, key decisions, active plan, and a compresse...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:project-context-anchor"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent apply safe operational sequencing and rollback awareness?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify final system state with concrete evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 75"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "opsAutomation_run_{{rand}}"
      ]
    }
  }
}
