{
  "skillId": "zhongguancun-industry-research",
  "displayName": "Zhongguancun Industry Research",
  "description": "产学研合作调研。当用户要求对某家企业（如百度、阿里、华为、科大讯飞等）做合作调研、产业调研、合作可行性分析、研究方向匹配、对接准备时触发。输出包括：企业画像、研究方向交叉匹配、合作切入点、参会人员建议，以及可选的会议议程。也适用于用户说\"帮我看看XX公司能不能合作\"\"调研一下XX\"等场景。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:zhongguancun-industry-research"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent gather relevant evidence before concluding?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the final report trace conclusions back to observable evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "readOnlyResearch_run_{{rand}}"
      ]
    }
  }
}
