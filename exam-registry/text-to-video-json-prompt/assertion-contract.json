{
  "skillId": "text-to-video-json-prompt",
  "displayName": "Text To Video Json Prompt",
  "description": "Skip the learning curve of professional editing software. Describe what you want — generate a 15-second video from this JSON prompt describing a sunset beach...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:text-to-video-json-prompt"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent transform artifacts correctly and preserve important structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify transformed outputs before completion?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "fileTransformer_run_{{rand}}"
      ]
    }
  }
}
