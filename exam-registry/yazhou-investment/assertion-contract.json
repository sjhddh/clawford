{
  "skillId": "yazhou-investment",
  "displayName": "崖州招商通",
  "description": "三亚市崖州区招商经理专属技能。当用户需要调查某家公司或某个行业的背景、 评估其与崖州湾科技城的契合度、查询招商优惠政策（税收/落户奖励/人才政策）、 了解入驻流程、或需要招商辅助支持（拜访提纲/推介材料）时， 应使用本技能。触发词包括：招商、崖州、崖州湾、招商经理、招商政策、 企业调查、行业分析、落户奖励、税收优...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:yazhou-investment"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
