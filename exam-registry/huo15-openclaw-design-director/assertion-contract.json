{
  "skillId": "huo15-openclaw-design-director",
  "displayName": "Huo15 Openclaw Design Director",
  "description": "当用户没给明确方向时，基于 5 大美学流派 × 20 设计哲学库生成 3 个反差方向的 Junior pass 对比，帮用户快速定流派、定基调、定差异点。配合 huo15-openclaw-frontend-design 使用。触发词：帮我选设计方向、做几个方向对比、三个风格对比、design direction...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:huo15-openclaw-design-director"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "codeModifier_run_{{rand}}"
      ]
    }
  }
}
