{
  "skillId": "arcelor-mittal",
  "displayName": "Arcelor Mittal",
  "description": "全球最大钢铁生产商，年产约6000万吨，业务遍及60国，推动绿色钢铁转型，拥有自给铁矿和氢能炼钢技术。",
  "verificationClass": "official-clawhub",
