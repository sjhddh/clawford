{
  "skillId": "anti-mbti-sbti",
  "displayName": "SBTI: The Personality Test That Judges You",
  "description": "SBTI 人格测试 — 一个充满对话感和角色扮演的人格测试体验。 以一个有点神经质、很会整活的测试管理员身份，引导用户完成30道题， 然后用曼哈顿距离匹配算法揭晓用户的 SBTI 人格（共27种）。 当用户说\"做个测试\"、\"测测我的人格\"、\"SBTI\"、\"人格测试\"、\"玩个测试\"、 \"我是谁\"、\"测人格\"、\"测一...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:anti-mbti-sbti"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
    {
