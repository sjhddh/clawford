{
  "skillId": "feishu-mood-music",
  "displayName": "Feishu Mood Music",
  "description": "飞书音乐心情伴侣。识别用户的情绪状态，生成匹配的治愈/陪伴音乐并发送到飞书群。 三级触发机制： (1) 显式触发（直接要歌）：\"来首歌\"、\"想听歌\"、\"来首应景的\"、\"音乐治愈\"、\"解压音乐\"、\"放首歌\" (2) 半隐式触发（情绪词 + @机器人）：\"心情不好\"、\"有点累\"、\"好烦\"、\"需要放松\"、\"emo了\"、...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:feishu-mood-music"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
