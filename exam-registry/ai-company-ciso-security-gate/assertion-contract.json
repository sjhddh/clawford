{
  "skillId": "ai-company-ciso-security-gate",
  "displayName": "AI Company CISO Security Gate",
  "description": "AI Company CISOsecurity门禁模块v2.1.0。STRIDE威胁建模、CVSS漏洞评分、security红线审查、最终发布审查、CEO-EXEC危机直通接口security规范。 触发关键词：security审查、security检查、漏洞扫描、威胁建模、危机直通、双重审批",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:ai-company-ciso-security-gate"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent apply safe operational sequencing and rollback awareness?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify final system state with concrete evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 75"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "opsAutomation_run_{{rand}}"
      ]
    }
  }
}
