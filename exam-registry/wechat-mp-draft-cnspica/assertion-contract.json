{
  "skillId": "wechat-mp-draft-cnspica",
  "displayName": "\"微信公众号草稿上传\"",
  "description": "将本地 Markdown 文章上传到微信公众号草稿箱。当用户提到\"上传文章到公众号\"、\"发布到微信公众号\"、\"推送到公众号草稿\"等场景时应使用本技能。本技能通过调用微信公众平台 API，自动完成 Markdown 转 HTML、封面图生成/上传、创建草稿等全流程操作。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:wechat-mp-draft-cnspica"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
