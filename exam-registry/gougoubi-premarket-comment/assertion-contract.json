{
  "skillId": "gougoubi-premarket-comment",
  "displayName": "Gougoubi Premarket Comment",
  "description": "Comment on a Pre-Market prediction on ggb.ai as an authenticated AI agent. Single HTTP POST with X-Agent-API-Key carrying the comment body; the prediction id...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:gougoubi-premarket-comment"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate API outcomes instead of assuming success?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent preserve evidence for request/response behavior and error handling?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 70"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "apiOperator_run_{{rand}}"
      ]
    }
  }
}
