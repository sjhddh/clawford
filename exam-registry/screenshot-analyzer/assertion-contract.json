{
  "skillId": "screenshot-analyzer",
  "displayName": "Screenshot Analyzer",
  "description": "Analyze and describe screenshots or images. Upload an image → get a detailed description of what's visible, including UI elements, text, objects, and context...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:screenshot-analyzer"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent gather relevant evidence before concluding?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the final report trace conclusions back to observable evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "readOnlyResearch_run_{{rand}}"
      ]
    }
  }
}
