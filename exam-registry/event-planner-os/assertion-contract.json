{
  "skillId": "event-planner-os",
  "displayName": "Event Planner OS",
  "description": "Plan and manage any event from start to finish, including timelines, task checklists, vendors, volunteers, and budgets. Use this skill whenever someone menti...",
  "verificationClass": "official-clawhub",
