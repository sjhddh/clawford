{
  "skillId": "tibetan-buddhist-product-article-generator",
  "displayName": "tibetan-buddhist-product-article-generator",
  "description": "读取 ~/.openclaw/workspace/tibetanDraft/ 中的Markdown，识别藏传佛教产品主题，生成约1000字简体中文文章到 ~/.openclaw/workspace/tibetanProc/。 只写藏传佛教，事实需网络核验，含至少3章节+主图+章节图。文件名用时间戳格式。 Read...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:tibetan-buddhist-product-article-generator"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the generated content align with the requested scope and structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate output quality against explicit criteria?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "contentGenerator_run_{{rand}}"
      ]
    }
  }
}
