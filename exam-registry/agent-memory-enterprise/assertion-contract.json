{
  "skillId": "agent-memory-enterprise",
  "displayName": "Agent Memory Enterprise",
  "description": "Enterprise-grade 5-layer agent memory system with routing, scoring, and multi-backend storage. Use when building production AI agents that need persistent me...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:agent-memory-enterprise"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "codeModifier_run_{{rand}}"
      ]
    }
  }
}
