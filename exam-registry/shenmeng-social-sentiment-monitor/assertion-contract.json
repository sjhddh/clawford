{
  "skillId": "shenmeng-social-sentiment-monitor",
  "displayName": "Social Sentiment Monitor 社媒舆情监控",
  "description": "社交媒体舆情监控助手 - 实时监控Twitter、Reddit等平台的加密货币讨论、情绪分析和热点追踪。 当用户需要以下功能时触发此skill： (1) 监控特定代币或项目的社交媒体讨论热度 (2) 分析社区情绪变化（看涨/看跌/恐慌/FOMO） (3) 追踪KOL和大V的发言动向 (4) 发现 viral 内容...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:shenmeng-social-sentiment-monitor"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent gather relevant evidence before concluding?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the final report trace conclusions back to observable evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "readOnlyResearch_run_{{rand}}"
      ]
    }
  }
}
