{
  "skillId": "revid-script-with-custom-media",
  "displayName": "Script + Custom Media",
  "description": "Render a video from a script using only the media assets the caller provides (no stock visuals). Use for branded content where every frame must be on-brand —...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:revid-script-with-custom-media"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the generated content align with the requested scope and structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate output quality against explicit criteria?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "contentGenerator_run_{{rand}}"
      ]
    }
  }
}
