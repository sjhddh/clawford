  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:best-suno-ai"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
