{
  "skillId": "generate-model-ready-test-cases-cn",
  "displayName": "generate-model-ready-test-cases-cn",
  "description": "生成标准化、模型可直接消费的自动化测试用例 JSON 套件。用于 Codex 需要根据需求文档、原型图、页面说明、接口文档、用户故事、缺陷描述或自然语言需求，产出可直接交给其他模型或自动化代理执行的测试用例时；尤其适用于 Web UI、API、端到端流程、回归、冒烟和验收场景。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:generate-model-ready-test-cases-cn"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent execute the browser workflow deterministically with explicit checkpoints?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify final browser state with concrete evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 70"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "browserWorkflow_run_{{rand}}"
      ]
    }
  }
}
