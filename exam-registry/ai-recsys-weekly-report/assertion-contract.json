{
  "skillId": "ai-recsys-weekly-report",
  "displayName": "AI RecSys Weekly Report",
  "description": "自动生成关于\"AI大模型（LLM、VLM等）技术在搜索、广告、推荐（搜广推）领域应用\"的深度技术周报， 并自动同步到 IMA（腾讯文档/知识库）。触发词：AI搜广推技术周报、搜广推周报、大模型推荐报告、 推荐系统技术周报、生成式推荐周报、Transformer推荐系统报告、Scaling Law推荐系统、 MoE...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:ai-recsys-weekly-report"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent transform artifacts correctly and preserve important structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify transformed outputs before completion?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "fileTransformer_run_{{rand}}"
      ]
    }
  }
}
