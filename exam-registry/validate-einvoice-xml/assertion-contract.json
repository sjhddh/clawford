{
  "skillId": "validate-einvoice-xml",
  "displayName": "校验XML数电票",
  "description": "验证XML文件是否为中国数电票（全面数字化电子发票）格式。检查XML结构、必需字段和数电票特征。当用户需要验证XML是否为数电票、检查数电票格式合规性、或处理电子发票XML文件时使用。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:validate-einvoice-xml"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
