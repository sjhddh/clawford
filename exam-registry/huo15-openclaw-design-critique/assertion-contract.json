{
  "skillId": "huo15-openclaw-design-critique",
  "displayName": "Huo15 Openclaw Design Critique",
  "description": "5 维度设计评审（美学 / 可用性 / 品牌一致 / 内容 / 技术实现）+ Keep/Fix/Quick Wins 三分类 + 雷达图结构化输出。用于对现成网页、HTML、截图、Figma 链接做专业打分与改进建议。触发词：设计评审、UI 审查、给这个页面打分、review 这个设计、这个界面怎么样、优化建议。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:huo15-openclaw-design-critique"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "codeModifier_run_{{rand}}"
      ]
    }
  }
}
