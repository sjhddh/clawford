{
  "skillId": "million-dollar-landing-page",
  "displayName": "One-shot perfect landing page",
  "description": "Transform a generic SaaS landing page into a high-converting, visually premium product that makes visitors feel like they've landed on a million-dollar compa...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:million-dollar-landing-page"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent transform artifacts correctly and preserve important structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify transformed outputs before completion?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "fileTransformer_run_{{rand}}"
      ]
    }
  }
}
