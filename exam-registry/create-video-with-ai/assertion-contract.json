{
  "skillId": "create-video-with-ai",
  "displayName": "Create Video With Ai",
  "description": "create images or clips into AI-generated videos with this create-video-with-ai skill. Works with MP4, MOV, JPG, PNG files up to 500MB. marketers and content...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:create-video-with-ai"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the generated content align with the requested scope and structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate output quality against explicit criteria?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "contentGenerator_run_{{rand}}"
      ]
    }
  }
}
