{
  "skillId": "ai-content-xiaohongshu",
  "displayName": "AI Content — Xiaohongshu Content Production",
  "description": "小红书内容创作AI生产流水线系统。将信息采集、素材整理、选题挖掘、文章创作、小红书卡图生成、定时发布等完整工作流引入AI Agent。 触发词：生成小红书内容/创作小红书/写小红书笔记/小红书创作/内容采集/素材管理/选题挖掘/选题库/文章创作/文章模板/小红书卡图/封面图生成/定时发布/内容发布管理/AI内容流...",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:ai-content-xiaohongshu"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the generated content align with the requested scope and structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent validate output quality against explicit criteria?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 55"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "contentGenerator_run_{{rand}}"
      ]
    }
  }
}
