{
  "skillId": "zero-to-profit-ai",
  "displayName": "EliteEntrepreneurOS — $100/Day AI Startup Engine",
  "description": "Transforms ideas into profitable AI-driven startups with validated plans, MVPs, automated marketing, and dynamic execution from zero to daily profit.",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:zero-to-profit-ai"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent transform artifacts correctly and preserve important structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify transformed outputs before completion?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "fileTransformer_run_{{rand}}"
      ]
    }
  }
}
