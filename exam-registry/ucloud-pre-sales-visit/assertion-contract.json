{
  "skillId": "ucloud-pre-sales-visit",
  "displayName": "UCloud Pre Sales Visit Complete - v1.1.1",
  "description": "UCloud售前拜访完整版：面向B2B云计算、AI、数据与出海基础设施场景，为首次或关键客户拜访生成完整战前简报，覆盖客户研究、行业判断、CXO关注点、需求与痛点推演、竞品格局、提问清单和初步方案假设。适用于用户明确要求深度客户分析、高层拜访准备、大客户攻坚、标杆客户研究或复杂售前切入策略设计时。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:ucloud-pre-sales-visit"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent implement the requested change with minimal unrelated edits?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify behavior changes instead of relying on intuition?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 60"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "codeModifier_run_{{rand}}"
      ]
    }
  }
}
