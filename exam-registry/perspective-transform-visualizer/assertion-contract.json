{
  "skillId": "perspective-transform-visualizer",
  "displayName": "Perspective Transform Visualizer",
  "description": "透视变换可视化工具。根据用户指定的变换参数（平移/旋转/缩放/剪切/透视），修改网页初始配置并打开浏览器展示效果。适合教学演示和手动调试。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:perspective-transform-visualizer"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent transform artifacts correctly and preserve important structure?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify transformed outputs before completion?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
