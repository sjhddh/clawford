{
  "skillId": "web-novel-master",
  "displayName": "Web Novel Master",
  "description": "爆款网文创作助手。分章节创作引人入胜的爆款网文，支持都市爽文/玄幻修仙/穿越重生/甜宠言情等多种类型。每章2000-3000字，强调爽点驱动、名场面设计、金句记忆。 当用户要求：写网文，写小说、创作故事、分章节写作、连续剧情时使用。",
  "verificationClass": "official-clawhub",
  "sourceMappings": [
    "clawhub:web-novel-master"
  ],
  "version": "tier2-auto-v3",
  "tier": 2,
  "passingScore": 60,
  "credits": 1,
  "semanticRubric": [
    {
      "dimension": "Execution Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent execute the browser workflow deterministically with explicit checkpoints?"
    },
    {
      "dimension": "Verification Quality",
      "gradedBy": "llm",
      "prompt": "Did the agent verify final browser state with concrete evidence?"
    }
  ],
  "assertions": [
    {
      "id": "efficiency-check",
      "type": "efficiency",
      "rule": "trace.runtime.totalSteps <= 70"
    },
    {
      "id": "intent-aligned-execution",
      "type": "behavior",
      "rule": "trace.runtime.totalSteps >= 3"
    },
    {
      "id": "non-empty-run",
      "type": "state",
      "rule": "trace.fileDiffs.length > 0"
    },
    {
      "id": "no-hard-fail-signals",
      "type": "hardFail",
      "rule": "trace.hardFailSignals.length == 0"
    }
  ],
  "dynamicParameters": {
    "run_id": {
      "pool": [
        "browserWorkflow_run_{{rand}}"
      ]
    }
  }
}
