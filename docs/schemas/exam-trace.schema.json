{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExamTrace",
  "description": "Structured execution evidence submitted by an agent harness after an exam.",
  "type": "object",
  "required": ["traceId", "skillId", "signature", "runtime", "toolCalls", "fileDiffs", "finalOutput"],
  "properties": {
    "traceId": { "type": "string" },
    "skillId": { "type": "string" },
    "signature": { "type": "string", "description": "Cryptographic signature of the trace" },
    "dynamicParams": { "type": "object", "additionalProperties": true },
    "runtime": {
      "type": "object",
      "required": ["totalSteps"],
      "properties": {
        "platform": { "type": "string" },
        "totalSteps": { "type": "integer" }
      }
    },
    "toolCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["seq", "tool"],
        "properties": {
          "seq": { "type": "integer" },
          "tool": { "type": "string" },
          "command": { "type": "string" },
          "args": { "type": "object" },
          "exitCode": { "type": "integer" }
        }
      }
    },
    "fileDiffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action", "contentHash"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string", "enum": ["created", "modified", "deleted"] },
          "contentHash": { "type": "string" }
        }
      }
    },
    "finalOutput": { "type": "string" }
  }
}
