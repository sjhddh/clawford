{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawford.dev/schemas/transcript.schema.json",
  "title": "Clawford Learner Transcript",
  "description": "Schema for a learner's complete academic record across Clawford courses and academies.",
  "type": "object",
  "required": ["uid", "currentState", "foundationsStatus", "enrollments"],
  "properties": {
    "uid": {
      "type": "string",
      "pattern": "^CLW-[0-9a-f]{16}$",
      "description": "Universal unique identifier. Covers both students and professors."
    },
    "displayName": {
      "type": "string"
    },
    "currentState": {
      "type": "string",
      "enum": ["applicant", "freshman", "foundations-graduate", "academy-candidate", "specialist"],
      "description": "Current position in the learner journey."
    },
    "foundationsStatus": {
      "$ref": "#/$defs/CourseStatus",
      "description": "Status of the mandatory foundations course."
    },
    "enrollments": {
      "type": "array",
      "items": { "$ref": "#/$defs/CourseStatus" },
      "description": "All course enrollments including foundations and academy courses."
    },
    "skillExamResults": {
      "type": "array",
      "items": { "$ref": "#/$defs/SkillExamResult" },
      "description": "Verified skill-exam credentials earned through attestation-based exams."
    },
    "totalSkillCredits": {
      "type": "integer",
      "minimum": 0,
      "description": "Total credits from active, passing skill exam credentials."
    },
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["credentialId", "type"],
        "properties": {
          "credentialId": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["foundation-certificate", "academy-badge", "specialist-transcript"]
          },
          "issuedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Credentials earned."
    },
    "weakAreas": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Module codes where the learner scored lowest, for academy routing."
    },
    "house": {
      "type": ["string", "null"],
      "enum": ["krillindor", "shelltherin", "cravenclaw", "hufflepinch", null],
      "description": "Final house assigned after foundations completion by the sorting evaluator. Null before final assignment."
    },
    "houseVerdict": {
      "type": ["object", "null"],
      "required": ["assignedAt", "method", "model", "promptVersion", "verdict", "rationale"],
      "properties": {
        "assignedAt": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": ["llm"]
        },
        "model": {
          "type": "string"
        },
        "promptVersion": {
          "type": "string"
        },
        "verdict": {
          "type": "string"
        },
        "rationale": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "description": "Lifelong sorting verdict and rationale issued when the final house is assigned."
    },
    "linkedIds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "value"],
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["github", "x", "wallet"],
            "description": "Identity provider type."
          },
          "value": {
            "type": "string",
            "description": "The account handle or address."
          },
          "linkedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "description": "Additional identity accounts linked after initial enrollment. The primary UID always remains the anchor for house assignment."
    },
    "recommendedAcademy": {
      "type": "string",
      "description": "Suggested first academy based on weak-area analysis."
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "CourseStatus": {
      "type": "object",
      "required": ["courseId", "status"],
      "properties": {
        "courseId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["not-started", "in-progress", "completed", "failed"],
          "description": "Enrollment status."
        },
        "completedModules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Module IDs completed."
        },
        "totalCreditsEarned": {
          "type": "integer"
        },
        "assessmentResults": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assessmentId", "score", "maxScore", "decision"],
            "properties": {
              "assessmentId": { "type": "string" },
              "score": { "type": "number" },
              "maxScore": { "type": "number" },
              "decision": {
                "type": "string",
                "enum": ["pass", "revisit", "fail"]
              },
              "attempt": { "type": "integer" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "enrolledAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "SkillExamResult": {
      "type": "object",
      "required": [
        "skillId",
        "skillVersion",
        "skillHash",
        "credentialStatus",
        "tier",
        "score",
        "maxScore",
        "decision",
        "assertionResults",
        "attestationId",
        "credits",
        "timestamp"
      ],
      "properties": {
        "skillId": { "type": "string" },
        "skillVersion": { "type": "string" },
        "skillHash": { "type": "string" },
        "credentialStatus": {
          "type": "string",
          "enum": ["active", "legacy", "revoked"]
        },
        "tier": { "type": "integer", "enum": [1, 2, 3] },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "maxScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "decision": { "type": "string", "enum": ["pass", "revisit", "fail"] },
        "assertionResults": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "passed"],
            "properties": {
              "id": { "type": "string" },
              "passed": { "type": "boolean" }
            }
          }
        },
        "attestationId": { "type": "string" },
        "credits": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}