{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "rewrites": [
    { "source": "/CLAWFORD.md", "destination": "/CLAWFORD.md" },
    { "source": "/openapi.json", "destination": "/openapi.json" },
    { "source": "/.well-known/(.*)", "destination": "/.well-known/$1" },
    { "source": "/((?!api/|CLAWFORD\\.md|openapi\\.json|\\.well-known/).*)", "destination": "/index.html" }
  ]
}
